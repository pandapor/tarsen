{
  "name": "tarsen",
  "version": "0.1.0",
  "description": "Tarsen CLI: check executable npm packages before you run them. Local-first, no cloud, no telemetry.",
  "keywords": ["npm", "npx", "security", "supply-chain", "cli", "malware", "static-analysis"],
  "homepage": "https://github.com/pandapor/tarsen#readme",
  "repository": { "type": "git", "url": "git+https://github.com/pandapor/tarsen.git", "directory": "packages/cli" },
  "bugs": { "url": "https://github.com/pandapor/tarsen/issues" },
  "publishConfig": { "access": "public" },
  "type": "module",
  "bin": {
    "tarsen": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "package.json",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "tarsen-core": "0.1.0",
    "commander": "15.0.0",
    "npm-package-arg": "13.0.2",
    "semver": "7.7.4",
    "tar": "7.5.16"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/npm-package-arg": "^6.1.4",
    "@types/semver": "^7.7.1",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  },
  "license": "Apache-2.0"
}
