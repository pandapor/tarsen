#!/usr/bin/env bash
# Build, test, and pack the publishable packages into ./outputs.
# Only core + cli are published; nothing else is bundled.
set -euo pipefail
mkdir -p "$PWD/outputs"
npm test
npm run build --workspace tarsen-core
npm run build --workspace tarsen
npm pack --workspace tarsen-core --pack-destination "$PWD/outputs"
npm pack --workspace tarsen --pack-destination "$PWD/outputs"
echo "Packages written to ./outputs"
